<?xml version="1.0" encoding="utf-8"?>
<!--
    AkaTrade AI - Data Extraction Rules (Android 12+)
    Cihaz transferi ve bulut yedekleme için hassas veri kısıtlamaları.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Finansal veritabanı ve ayarlar bulut yedeklemesine DAHİL DEĞİLDİR -->
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Cihaz transferinde de aynı kısıtlamalar geçerli -->
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
