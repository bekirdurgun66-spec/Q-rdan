<?xml version="1.0" encoding="utf-8"?>
<!--
    AkaTrade AI - Auto Backup Rules
    Hassas finansal verilerin bulut yedeklemesini engelle.
    Not: AndroidManifest.xml'de allowBackup="false" ile tamamen devre dışı bırakıldı,
    bu kurallar defense-in-depth olarak eklenmiştir.
-->
<full-backup-content>
    <!-- Veritabanı dizinini yedekleme kapsamından çıkar -->
    <exclude domain="database" path="." />
    <!-- SharedPreferences'i yedekleme kapsamından çıkar -->
    <exclude domain="sharedpref" path="." />
    <!-- Sadece önbellek ve UI state'lerine izin ver -->
    <include domain="file" path="." />
</full-backup-content>
