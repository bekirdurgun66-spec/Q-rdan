            <pin digest="SHA-256">6rQb9WdLsTAXq5d8qEx6C68pNbZh6YyT1RWpD5fveUs=</pin>
            <!-- Yedek (ara CA): CN=WE2, O=Google Trust Services -->
            <pin digest="SHA-256">vh78KSg1Ry4NaqGDV10w/cTb9VH3BQUZoCWNa93W/EY=</pin>
        </pin-set>
    </domain-config>
</network-security-config>
