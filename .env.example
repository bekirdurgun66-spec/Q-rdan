# PROXY_BASE_URL: Firebase Cloud Function URL that proxies Gemini API calls.
# Deploy the function first via 'firebase deploy --only functions', then set the URL here.
# For v1 Cloud Functions the format is: https://<REGION>-<PROJECT_ID>.cloudfunctions.net/
# The endpoint name 'generateContent' is appended automatically in the Retrofit interface.
PROXY_BASE_URL=https://us-central1-MY_PROJECT_ID.cloudfunctions.net/

# PROXY_API_KEY: (İsteğe bağlı) Proxy kimlik doğrulama anahtarı.
# Eğer Cloud Function'da proxy auth aktif edilirse, aynı değeri sunucu tarafında da ayarlayın:
#   firebase functions:config:set proxy.api_key="BU_DEGER"
# Kimlik doğrulama kullanılmıyorsa MY_PROXY_API_KEY olarak bırakabilirsiniz.
PROXY_API_KEY=MY_PROXY_API_KEY
